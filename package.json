{
  "name": "campus-norma",
  "version": "1.0.0",
  "private": true,
  "description": "Campus Norma - Plataforma de cursos online (frontend + backend Express + SQLite)",
  "scripts": {
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "dev": "concurrently -n backend,frontend -c blue,magenta \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "start": "npm --prefix backend start",
    "init:db": "cd backend && node scripts/init-db.js",
    "seed": "cd backend && node scripts/seed.js",
    "lint:check": "echo 'lint placeholder'"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
