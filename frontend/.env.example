# Variables del Frontend (Vite). Copiar a frontend/.env
# Solo variables con prefijo VITE_ se exponen al cliente.

# URL base del backend SIN /api al final (api.ts ya prefijea /api a las rutas)
# Desarrollo:
VITE_API_URL=http://localhost:5000

# Produccion (ejemplo):
# VITE_API_URL=https://campus-norma-backend.onrender.com

# MercadoPago Public Key (NUNCA el access token)
VITE_MERCADOPAGO_PUBLIC_KEY=

VITE_APP_NAME=Campus Norma
