# ============================================================================
# Campus Norma - Variables de entorno
# Copiar a .env y completar valores reales. NUNCA commitear .env real.
# ============================================================================

# --- Modo de ejecucion ---
NODE_ENV=development
PORT=5000

# --- URLs publicas ---
# URL publica del frontend (CORS, back_urls de MercadoPago)
FRONTEND_URL=http://localhost:3000
# URL publica del backend (para que MercadoPago envie el webhook).
# En local, usar ngrok/cloudflared para exponer http://localhost:5000.
BACKEND_URL=http://localhost:5000

# --- Base de datos y uploads (paths persistentes) ---
# Por defecto la DB SQLite vive en backend/database/campus_norma.db.
# En Render con disk persistente: setear estas dos para que NO se pierdan en cada deploy.
# DB_FILE=/var/data/campus_norma.db
# UPLOADS_DIR=/var/data/uploads

# --- Autenticacion ---
# CAMBIAR ESTO. Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar_por_secreto_aleatorio_largo
JWT_EXPIRES_IN=7d

# --- MercadoPago ---
# Conseguir en https://www.mercadopago.com.ar/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# --- Email (opcional, recomendado para produccion) ---
# Sin nada de esto, los emails se loggean en consola (modo dev).
#
# Opcion 1 - Resend (recomendado, free 100 mails/dia):
#   1. Sign up en https://resend.com (login con GitHub)
#   2. API Keys → Create → copiar la key
#   3. Domains → agregar tu dominio (o usar onboarding@resend.dev de prueba)
# RESEND_API_KEY=re_xxxxxxxxxx
# EMAIL_FROM="Campus Norma <noreply@tudominio.com>"
# EMAIL_REPLY_TO=soporte@tudominio.com
#
# Opcion 2 - SMTP (Gmail, Brevo, etc.):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu@gmail.com
# SMTP_PASS=app_password_de_gmail

# --- CORS adicional (opcional, separado por comas) ---
# CORS_ORIGIN=https://tudominio.com,https://www.tudominio.com

# --- Admin por defecto (solo se usa al inicializar la DB vacia) ---
ADMIN_EMAIL=admin@campusnorma.com
ADMIN_PASSWORD=cambiar_en_produccion

# --- Frontend (Vite) ---
# Estas se leen desde frontend/.env (no este archivo)
# VITE_API_URL=http://localhost:5000
